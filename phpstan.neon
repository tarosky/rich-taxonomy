includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
    - phpstan-baseline.neon

parameters:
    bootstrapFiles:
        - phpstan-bootstrap.php
    level: 5
    paths:
        - rich-taxonomy.php
        - functions.php
        - src/
    excludePaths:
        analyseAndScan:
            - node_modules (?)
